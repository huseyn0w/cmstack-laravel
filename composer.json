{
    "name": "huseyn0w/larapress",
    "type": "project",
    "description": "LaraPress — the Laravel version of WordPress.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-imagick": "*",
        "astrotomic/laravel-translatable": "^11.15",
        "genealabs/laravel-model-caching": "^13.0",
        "google/recaptcha": "^1.3",
        "guzzlehttp/guzzle": "^7.8",
        "intervention/image": "^2.7",
        "laravel/framework": "^11.0",
        "laravel/helpers": "^1.7",
        "laravel/mcp": "^0.8.1",
        "laravel/passport": "^13.7",
        "laravel/socialite": "^5.12",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.0",
        "mews/purifier": "^3.4",
        "unisharp/laravel-filemanager": "^2.9"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "barryvdh/laravel-ide-helper": "^3.0",
        "fakerphp/faker": "^1.23",
        "filp/whoops": "^2.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeds/"
        },
        "files": [
            "bootstrap/larapress-helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
      "post-autoload-dump": [
        "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
        "@php artisan package:discover --ansi"
      ],
      "post-root-package-install": [
        "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
      ],
      "post-create-project-cmd": [
        "@php artisan key:generate --ansi"
      ],
      "setup": [
        "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
        "@php artisan key:generate --ansi",
        "@php artisan migrate --seed --force",
        "@php artisan storage:link --ansi"
      ]
    }
}
